{
  "manifest_version": 3,
  "name": "Torn Company Manager",
  "default_locale": "zh_CN",
  "version": "1.0.0",
  "description": "Torn City 公司管理工具 - 员工、训练、库存、财务、毒瘾监控、Boost管理",
  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://api.torn.com/*",
    "https://www.torn.com/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "torn-company-manager@hermes",
      "strict_min_version": "109.0"
    }
  },
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
